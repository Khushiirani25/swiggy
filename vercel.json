{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/app/:path*", "destination": "/app/index.html" },
    { "source": "/partner/:path*", "destination": "/partner/index.html" },
    { "source": "/driver/:path*", "destination": "/driver/index.html" },
    { "source": "/admin/:path*", "destination": "/admin/index.html" }
  ]
}
